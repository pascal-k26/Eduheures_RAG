# ── Azure OpenAI — Modèle de chat ─────────────────────────────────────────────
OPENAI_API_KEY=votre_cle_chat
OPENAI_API_ENDPOINT=https://votre-ressource.openai.azure.com/
AZURE_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_CHAT_API_VERSION=2024-10-21

# ── Azure OpenAI — Embeddings ─────────────────────────────────────────────────
OPENAI_EMBEDDING_API_KEY=votre_cle_embedding
OPENAI_EMBEDDING_API_ENDPOINT=https://votre-ressource-embedding.openai.azure.com/
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2023-05-15

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://votre-cluster.qdrant.io
QDRANT_API_KEY=votre_cle_qdrant
QDRANT_COLLECTION=uvci_documents

# ── Recherche web agentique (choisir au moins un) ─────────────────────────────
TAVILY_API_KEY=tvly-...          # Recommandé — https://tavily.com
SERPER_API_KEY=votre_cle_serper  # Alternative — https://serper.dev
# Si aucune clé n'est définie, DuckDuckGo est utilisé en fallback (gratuit)

# ── Sécurité API ──────────────────────────────────────────────────────────────
API_SECRET_KEY=une_cle_secrete_forte   # Optionnel — laissez vide en dev

# ── CORS (domaines autorisés, séparés par des virgules) ──────────────────────
ALLOWED_ORIGINS=http://localhost:5500,https://votre-frontend.com

# ── Environnement ─────────────────────────────────────────────────────────────
ENV=development   # "development" active /docs et le rechargement automatique
